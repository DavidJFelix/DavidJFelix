{
  "name": "@davidjfelix/monicandavid.com",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3003",
    "prepare": "svelte-kit sync && panda codegen",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "pnpm run build && wrangler deploy",
    "lint": "biome check . && oxlint",
    "lint:fix": "biome check --write .",
    "format": "biome format . && prettier --check --no-error-on-unmatched-pattern \"**/*.md\" \"**/*.mdx\"",
    "format:fix": "biome format --write . && prettier --write --no-error-on-unmatched-pattern \"**/*.md\" \"**/*.mdx\"",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@ark-ui/svelte": "^5.22.1",
    "@sentry/browser": "^10.59.0",
    "posthog-js": "^1.391.2"
  },
  "devDependencies": {
    "@pandacss/dev": "1.11.3",
    "@playwright/test": "1.60.0",
    "@sveltejs/adapter-cloudflare": "7.2.8",
    "@sveltejs/kit": "2.65.1",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@types/node": "25.9.3",
    "svelte": "5.56.3",
    "svelte-check": "4.6.0",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.8",
    "wrangler": "4.100.0"
  }
}
