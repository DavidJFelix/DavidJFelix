{
  "name": "@davidjfelix/alchemy-state-viewer",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3007",
    "prepare": "svelte-kit sync",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "pnpm run build && wrangler deploy",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "biome check . && oxlint",
    "lint:fix": "biome check --write . && oxlint --fix",
    "format": "oxfmt --check . && prettier --check --no-error-on-unmatched-pattern \"**/*.md\" \"**/*.mdx\"",
    "format:fix": "oxfmt . && prettier --write --no-error-on-unmatched-pattern \"**/*.md\" \"**/*.mdx\"",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260711.1",
    "@sveltejs/adapter-cloudflare": "^7.2.4",
    "@sveltejs/kit": "^2.27.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.5",
    "@vitest/coverage-v8": "^4.1.10",
    "svelte": "^5.46.1",
    "svelte-check": "^4.3.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
