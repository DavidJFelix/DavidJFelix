{
  "name": "ravrun",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "dev": "vite --port=3001",
    "build": "vite build",
    "serve": "vite preview",
    "start": "vite",
    "lint": "biome check . && oxlint",
    "lint:fix": "biome check --write .",
    "format": "biome format . && prettier --check --no-error-on-unmatched-pattern \"**/*.md\" \"**/*.mdx\"",
    "format:fix": "biome format --write . && prettier --write --no-error-on-unmatched-pattern \"**/*.md\" \"**/*.mdx\"",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots"
  },
  "devDependencies": {
    "@playwright/test": "1.61.0",
    "@tailwindcss/vite": "4.3.1",
    "@tanstack/router-plugin": "1.168.18",
    "@types/bun": "1.3.14",
    "@types/node": "25.9.4",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "latest",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.9",
    "jsdom": "29.1.1",
    "tailwindcss": "4.3.1",
    "vite": "8.0.16",
    "vitest": "4.1.9",
    "wrangler": "4.103.0"
  },
  "dependencies": {
    "@sentry/cloudflare": "^10.60.0",
    "@sentry/react": "^10.60.0",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/router-devtools": "^1.167.0",
    "date-fns": "^4.4.0",
    "posthog-js": "^1.393.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "engines": {
    "node": ">=24"
  }
}
