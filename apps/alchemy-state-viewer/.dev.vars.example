# Copy to .dev.vars (gitignored) for local dev.

# Base URL of the alchemy Cloudflare state store worker. On the deployed
# worker this is the one plain secret: `wrangler secret put ALCHEMY_STATE_URL`.
ALCHEMY_STATE_URL=https://alchemy-state-store.<your-subdomain>.workers.dev

# Local-dev override for the bearer token. The DEPLOYED worker does not use
# this variable: it reads the token through the `ALCHEMY_STATE_TOKEN_SECRET`
# Secrets Store binding in wrangler.toml (secret `AlchemyStateStoreToken`,
# the one the alchemy bootstrap already maintains), so the value is never
# copied around. For local dev, paste the `authToken` from
# ~/.alchemy/credentials/<profile>/cloudflare-state-store.
ALCHEMY_STATE_TOKEN=

# The app does no authentication of its own. The deployed worker MUST sit
# behind Cloudflare Access (enable Access on its workers.dev route) before
# ALCHEMY_STATE_URL is configured.
