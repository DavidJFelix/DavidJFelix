---
import '../index.css'
import '@fontsource-variable/schibsted-grotesk'
import '@fontsource-variable/inter'
import interLatinWoff2 from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url'
import schibstedLatinWoff2 from '@fontsource-variable/schibsted-grotesk/files/schibsted-grotesk-latin-wght-normal.woff2?url'
import type {IconDefinition} from '@fortawesome/free-brands-svg-icons'
import {faGithub, faXTwitter} from '@fortawesome/free-brands-svg-icons'
import {css} from 'styled-system/css'
import Analytics from '../components/Analytics.astro'
import Search from '../components/Search.astro'
import ThemeToggle from '../components/ThemeToggle.astro'
import {publicationUri} from '../lib/standard-site'

interface Props {
  title: string
  description?: string
  ogType?: 'website' | 'article'
  ogImage?: string
  ogImageAlt?: string
  // Rendered as article:* OpenGraph meta; only articles pass it.
  article?: {publishedTime: string; author: string; tags?: Array<string>}
  // Head extras are rendered directly here rather than forwarded through a
  // `<slot name="head" />`: Astro 7 does not render a named slot placed inside
  // `<head>` (the slot is received but emits nothing), which silently dropped
  // the JSON-LD and standard-site link on every blog post.
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>
  standardDocumentUri?: string | null
}

const {
  title,
  description = 'Personal blog of David J Felix',
  ogType = 'website',
  ogImage = '/og/default.png',
  ogImageAlt = 'Title card for djf.io, the blog of David J Felix',
  article,
  jsonLd,
  standardDocumentUri,
} = Astro.props

// Pages build with the default directory format, so published URLs end with a
// trailing slash; normalize the canonical to match what the sitemap emits.
const pathname = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`
const canonicalUrl = Astro.site ? new URL(pathname, Astro.site) : undefined
const ogImageUrl = Astro.site ? new URL(ogImage, Astro.site) : undefined

// JSON.stringify leaves "<" unescaped, so a value containing "</script>"
// would close the inline tag early; < is the standard JSON-safe escape.
const jsonLdPayloads = (Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : []).map((item) =>
  JSON.stringify(item).replace(/</gu, '\\u003c'),
)

// Only ship analytics on builds that carry the key (production deploy). The
// component guards on the key at runtime too; gating the render here keeps it
// out of local/CI/preview output entirely.
const posthogEnabled = Boolean(import.meta.env.PUBLIC_POSTHOG_KEY)

// FontAwesome brand glyphs, rendered as static inline SVGs at build time so
// no icon font or client JS ships. The X logo stands in for the word in the
// desktop row, but the accessible name and the mobile menu keep saying
// Twitter.
const navLinks: Array<{href: string; label: string; icon?: IconDefinition}> = [
  {href: '/blog', label: 'Blog'},
  {href: '/about', label: 'About'},
  {href: 'https://github.com/davidjfelix', label: 'GitHub', icon: faGithub},
  {href: 'https://twitter.com/davidjfelix', label: 'Twitter', icon: faXTwitter},
]

// icon[4] is the path data: one string, or several for layered glyphs.
const iconPaths = ({icon}: IconDefinition) => (Array.isArray(icon[4]) ? icon[4] : [icon[4]])

const navLink = css({
  color: 'text.muted',
  textDecoration: 'none',
  _hover: {color: 'text'},
})

const navIconLink = css({
  display: 'flex',
  alignItems: 'center',
  color: 'text.muted',
  _hover: {color: 'text'},
})

// Padding grows the tap target past the WCAG 24px minimum; the negative
// margin keeps the icon's layout footprint unchanged in the header row.
const navToggle = css({
  display: {base: 'flex', md: 'none'},
  alignItems: 'center',
  justifyContent: 'center',
  p: '2',
  m: '-2',
  color: 'text.muted',
  bg: 'transparent',
  cursor: 'pointer',
  borderRadius: 'sm',
  _hover: {color: 'text'},
  _focusVisible: {outline: '2px solid', outlineColor: 'focus.ring', outlineOffset: '2px'},
})

// The [hidden] override must beat the display token below, since a class
// setting display would otherwise win over the UA's [hidden] rule.
const menuPanel = css({
  display: {base: 'flex', md: 'none'},
  flexDirection: 'column',
  gap: '4',
  pt: '4',
  '&[hidden]': {display: 'none'},
})

// Icons swap on the button's own aria-expanded, same pattern as ThemeToggle's
// data-theme swap: bars while closed, an X while open.
const iconMenuClosed = css({'#nav-toggle[aria-expanded=true] &': {display: 'none'}})
const iconMenuOpen = css({display: 'none', '#nav-toggle[aria-expanded=true] &': {display: 'block'}})
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {/* Resolve the color theme before first paint so there is no flash: an
        explicit choice in localStorage wins, otherwise follow the system. */}
    <script is:inline>
      const storedTheme = localStorage.getItem('theme')
      document.documentElement.dataset.theme =
        storedTheme === 'light' || storedTheme === 'dark'
          ? storedTheme
          : matchMedia('(prefers-color-scheme: dark)').matches
            ? 'dark'
            : 'light'
    </script>
    {/* Tag the platform before first paint so the search hotkey hint renders as
        ⌘K (Mac) or Ctrl K immediately, instead of flashing after hydration. */}
    <script is:inline>
      if (/Mac|iPhone|iPad|iPod/.test(navigator.userAgent)) {
        document.documentElement.dataset.platform = 'mac'
      }
    </script>
    {/* Latin is the only subset these pages use; preloading the two woff2s
        that style above-the-fold text skips the CSS-then-font round trip.
        fontsource@5 ships no per-subset CSS, but its unicode-range rules
        already keep the other subsets from downloading. */}
    <link rel="preload" as="font" type="font/woff2" href={interLatinWoff2} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={schibstedLatinWoff2} crossorigin />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | djf.io</title>
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="djf.io" />
    <meta property="og:locale" content="en_US" />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    {ogImageUrl && <meta property="og:image:width" content="1200" />}
    {ogImageUrl && <meta property="og:image:height" content="630" />}
    {ogImageUrl && <meta property="og:image:alt" content={ogImageAlt} />}
    {article && <meta property="article:published_time" content={article.publishedTime} />}
    {article && <meta property="article:author" content={article.author} />}
    {article?.tags?.map((tag) => <meta property="article:tag" content={tag} />)}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@davidjfelix" />
    <meta name="twitter:creator" content="@davidjfelix" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
    {ogImageUrl && <meta name="twitter:image:alt" content={ogImageAlt} />}
    <link
      rel="alternate"
      type="application/rss+xml"
      title="David J. Felix's Blog"
      href="/rss.xml"
    />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="site.standard.publication" href={publicationUri()} />
    {posthogEnabled && <Analytics />}
    {jsonLdPayloads.map((payload) => (
      <script is:inline type="application/ld+json" set:html={payload} />
    ))}
    {standardDocumentUri && <link rel="site.standard.document" href={standardDocumentUri} />}
  </head>
  <body
    class={css({
      fontFamily: 'body',
      bg: 'bg.canvas',
      color: 'text',
      minH: '100vh',
      lineHeight: '1.6',
    })}
  >
    <header
      class={css({
        borderBottom: '1px solid',
        borderBottomColor: 'border.subtle',
        py: '4',
      })}
    >
      <nav class={css({maxW: '3xl', mx: 'auto', px: '4'})}>
        <div
          class={css({
            display: 'flex',
            justifyContent: 'space-between',
            alignItems: 'center',
          })}
        >
          <a
            href="/"
            class={css({
              fontSize: 'xl',
              fontWeight: 'bold',
              color: 'text',
              textDecoration: 'none',
              _hover: {color: 'accent.text'},
            })}
          >
            djf.io
          </a>
          <div class={css({display: 'flex', alignItems: 'center', gap: '6'})}>
            <Search />
            <div
              class={css({
                display: {base: 'none', md: 'flex'},
                alignItems: 'center',
                gap: '6',
              })}
            >
              {navLinks.map(({href, label, icon}) =>
                icon ? (
                  <a href={href} aria-label={label} title={label} class={navIconLink}>
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="18"
                      height="18"
                      viewBox={`0 0 ${icon.icon[0]} ${icon.icon[1]}`}
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      {iconPaths(icon).map((d) => (
                        <path d={d}></path>
                      ))}
                    </svg>
                  </a>
                ) : (
                  <a href={href} class={navLink}>{label}</a>
                ),
              )}
            </div>
            <button
              type="button"
              id="nav-toggle"
              aria-label="Open menu"
              aria-expanded="false"
              aria-controls="nav-menu"
              class={navToggle}
            >
              <svg
                class={iconMenuClosed}
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <line x1="4" x2="20" y1="6" y2="6"></line>
                <line x1="4" x2="20" y1="12" y2="12"></line>
                <line x1="4" x2="20" y1="18" y2="18"></line>
              </svg>
              <svg
                class={iconMenuOpen}
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M18 6 6 18"></path>
                <path d="m6 6 12 12"></path>
              </svg>
            </button>
            <ThemeToggle />
          </div>
        </div>
        <div id="nav-menu" class={menuPanel}>
          {navLinks.map(({href, label}) => (
            <a href={href} class={navLink}>{label}</a>
          ))}
        </div>
        {/* The panel ships open so the links stay reachable without JavaScript;
            with it, collapse before first paint and let the toggle take over. */}
        <script is:inline>
          const navMenu = document.getElementById('nav-menu')
          if (navMenu) navMenu.hidden = true
        </script>
      </nav>
    </header>

    <main
      class={css({
        maxW: '3xl',
        mx: 'auto',
        px: '4',
        py: '8',
      })}
    >
      <slot />
    </main>

    <footer
      class={css({
        borderTop: '1px solid',
        borderTopColor: 'border.subtle',
        py: '6',
        mt: '12',
      })}
    >
      <div
        class={css({
          maxW: '3xl',
          mx: 'auto',
          px: '4',
          textAlign: 'center',
          color: 'text.muted',
          fontSize: 'sm',
        })}
      >
        &copy; David J Felix
      </div>
    </footer>

    <script>
      const toggle = document.querySelector<HTMLButtonElement>('#nav-toggle')
      const menu = document.querySelector<HTMLElement>('#nav-menu')
      if (toggle && menu) {
        const setOpen = (open: boolean) => {
          toggle.setAttribute('aria-expanded', String(open))
          toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu')
          menu.hidden = !open
        }
        toggle.addEventListener('click', () => setOpen(Boolean(menu.hidden)))
        window.addEventListener('keydown', (event) => {
          if (event.key === 'Escape' && !menu.hidden) setOpen(false)
        })
      }
    </script>
  </body>
</html>
