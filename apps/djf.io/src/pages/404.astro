---
import {css} from 'styled-system/css'
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Page not found" description="The page you were looking for does not exist.">
  <section
    class={css({
      display: 'flex',
      flexDirection: 'column',
      alignItems: 'center',
      textAlign: 'center',
      gap: '4',
      py: '16',
    })}
  >
    <p
      class={css({
        fontFamily: 'mono',
        fontSize: '7xl',
        fontWeight: 'bold',
        lineHeight: '1',
        color: 'accent.text',
      })}
    >
      404
    </p>
    <h1 class={css({fontSize: '3xl', fontWeight: 'bold'})}>Page not found</h1>
    <p class={css({color: 'text.muted', fontSize: 'lg', maxW: 'md'})}>
      It's all downhill from here &mdash; but this particular path doesn't exist.
    </p>
    <a
      href="/"
      class={css({
        mt: '2',
        color: 'accent.text',
        textDecoration: 'none',
        fontSize: 'lg',
        _hover: {textDecoration: 'underline'},
      })}
    >
      &larr; Back home
    </a>
  </section>
</BaseLayout>
