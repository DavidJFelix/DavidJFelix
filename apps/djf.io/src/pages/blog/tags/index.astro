---
import {getCollection} from 'astro:content'
import {css} from 'styled-system/css'
import BaseLayout from '../../../layouts/BaseLayout.astro'
import {tagCountsDesc} from '../../../lib/blog'

const sortedTags = tagCountsDesc(await getCollection('blog'))
---

<BaseLayout title="Tags" description="Browse blog posts by tag">
  <h1
    class={css({
      fontSize: '3xl',
      fontWeight: 'bold',
      mb: '8',
    })}
  >
    Tags
  </h1>

  <div class={css({display: 'flex', flexWrap: 'wrap', gap: '3'})}>
    {
      sortedTags.map(([tag, count]) => (
        <a
          href={`/blog/tags/${tag}`}
          class={css({
            bg: 'bg.subtle',
            color: 'text.muted',
            px: '4',
            py: '2',
            borderRadius: 'md',
            borderWidth: '1px',
            borderStyle: 'solid',
            borderColor: 'border.subtle',
            textDecoration: 'none',
            fontSize: 'sm',
            transition: 'border-color 0.2s',
            _hover: {borderColor: 'border', color: 'text'},
          })}
        >
          {tag}
          <span class={css({color: 'text.muted', ml: '2'})}>{count}</span>
        </a>
      ))
    }
  </div>
</BaseLayout>
