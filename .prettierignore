# Prettier is only used for Markdown and MDX files; Biome formats everything else.
#
# Recipe: ignore every file at every depth (`**`), then re-include directories
# (`!*/`) so prettier still descends the tree, then re-include md/mdx at any
# depth. The previous `*` + `!**/*.md` form excluded directories outright, so the
# negations could never reach nested files (gitignore semantics).
**
!*/
!*.md
!*.mdx

# Apps own their markdown through their per-app format gates (each app runs
# prettier itself; djf.io excludes its semantic-line-break blog content via its
# own .prettierignore, which a root-level run would not honor).
apps/

# Verbatim license legal codes keep their canonical line structure; rewrapping
# a legal text is not a formatting fix.
docs/LICENSE.CC0-1.0.md

# Out-of-scope trees: legacy dirs, isolated workspace trees, vendored skills
# whose content hashes are pinned in skills-lock.json, and the .claude symlink
# surface into .agents.
Exercism/
workspaces/
dotfiles/
.agents/
.claude/

# ...but never descend into generated or vendored trees, even for their markdown.
node_modules/
dist/
build/
.astro/
.svelte-kit/
.nuxt/
.output/
.vinxi/
.wrangler/
.vercel/
styled-system/
