{
  "name": "calendar-visualizer",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "prepare": "panda codegen",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check",
    "lint": "biome check . && oxlint",
    "lint:fix": "biome check --write .",
    "format": "biome format . && prettier --check --no-error-on-unmatched-pattern \"**/*.md\" \"**/*.mdx\"",
    "format:fix": "biome format --write . && prettier --write --no-error-on-unmatched-pattern \"**/*.md\" \"**/*.mdx\"",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "spell": "cspell --config ../../.config/cspell.json \"**\""
  },
  "dependencies": {
    "@astrojs/react": "^5.0.7",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.4.6",
    "date-fns": "^4.4.0",
    "date-holidays": "^3.30.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@cspell/dict-typescript": "3.2.3",
    "@pandacss/dev": "1.11.3",
    "@types/bun": "1.3.14",
    "@vitest/coverage-v8": "4.1.8",
    "cspell": "10.0.1",
    "vitest": "4.1.8",
    "wrangler": "4.100.0"
  }
}
