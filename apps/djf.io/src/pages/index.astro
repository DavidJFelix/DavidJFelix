---
import {Image} from 'astro:assets'
import {getCollection} from 'astro:content'
import {css} from 'styled-system/css'
import headshot from '../assets/headshot.png'
import BaseLayout from '../layouts/BaseLayout.astro'
import {formatBlogDate, sortPostsByDateDesc} from '../lib/blog'

const recentPosts = sortPostsByDateDesc(await getCollection('blog')).slice(0, 3)
---

<BaseLayout title="David J Felix" description="Personal blog of David J Felix">
  <div class={css({display: 'flex', flexDirection: 'column', gap: '12'})}>
    <section
      class={css({
        display: 'flex',
        flexDirection: {base: 'column', md: 'row'},
        alignItems: 'center',
        gap: '8',
      })}
    >
      <Image
        src={headshot}
        alt="David J Felix"
        class={css({
          w: '40',
          h: '40',
          borderRadius: 'full',
          borderWidth: '4px',
          borderStyle: 'solid',
          borderColor: 'border',
        })}
      />
      <div>
        <h1 class={css({fontSize: '4xl', fontWeight: 'bold', mb: '2'})}>David J Felix</h1>
        <p class={css({color: 'text.muted', fontSize: 'lg'})}>It's all downhill from here</p>
      </div>
    </section>

    <section>
      <div
        class={css({
          display: 'flex',
          alignItems: 'baseline',
          justifyContent: 'space-between',
          mb: '6',
        })}
      >
        <h2 class={css({fontSize: '2xl', fontWeight: 'bold'})}>Recent posts</h2>
        <a
          href="/blog"
          class={css({
            color: 'accent.text',
            textDecoration: 'none',
            fontSize: 'sm',
            _hover: {textDecoration: 'underline'},
          })}
        >
          All posts &rarr;
        </a>
      </div>

      <div class={css({display: 'flex', flexDirection: 'column', gap: '6'})}>
        {
          recentPosts.map((post) => (
            <article
              class={css({
                p: '6',
                bg: 'bg.subtle',
                borderRadius: 'lg',
                borderWidth: '1px',
                borderStyle: 'solid',
                borderColor: 'border.subtle',
                transition: 'border-color 0.2s',
                _hover: {borderColor: 'border'},
              })}
            >
              <a href={`/blog/${post.id}`} class={css({textDecoration: 'none'})}>
                <h3
                  class={css({
                    fontSize: 'xl',
                    fontWeight: 'semibold',
                    color: 'text',
                    mb: '2',
                    _hover: {color: 'accent.text'},
                  })}
                >
                  {post.data.title}
                </h3>
              </a>
              <p class={css({color: 'text.muted', mb: '3', fontSize: 'sm'})}>
                {post.data.description}
              </p>
              <div
                class={css({
                  display: 'flex',
                  flexWrap: 'wrap',
                  gap: '3',
                  color: 'text.muted',
                  fontSize: 'xs',
                })}
              >
                <span>{formatBlogDate(post.data.date)}</span>
                {post.data.readingTime && <span>{post.data.readingTime} read</span>}
              </div>
            </article>
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>
