{
  "name": "calendar-visualizer",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "prepare": "panda codegen",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check",
    "lint": "biome check . && oxlint",
    "lint:fix": "biome check --write . && oxlint --fix",
    "format": "oxfmt --check . && biome format . && prettier --check --no-error-on-unmatched-pattern \"**/*.md\" \"**/*.mdx\"",
    "format:fix": "oxfmt . && biome format --write . && prettier --write --no-error-on-unmatched-pattern \"**/*.md\" \"**/*.mdx\"",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.0.0",
    "@astrojs/react": "^6.0.0",
    "@sentry/astro": "^10.60.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro": "^7.0.0",
    "date-fns": "^4.4.0",
    "date-holidays": "^3.30.2",
    "posthog-js": "^1.393.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@pandacss/dev": "1.11.4",
    "@playwright/test": "1.61.1",
    "@sentry/cloudflare": "10.67.0",
    "@types/bun": "1.3.14",
    "@vitest/coverage-v8": "4.1.10",
    "vitest": "4.1.10",
    "wrangler": "4.112.0"
  }
}
