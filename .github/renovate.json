{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":dependencyDashboard"
  ],
  "timezone": "UTC",
  "schedule": ["before 5am on monday"],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 5am on monday"]
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  },
  "packageRules": [
    {
      "matchUpdateTypes": ["patch", "minor"],
      "matchManagers": ["npm"],
      "groupName": "npm patch/minor"
    },
    {
      "matchUpdateTypes": ["patch", "minor"],
      "matchManagers": ["cargo"],
      "groupName": "cargo patch/minor"
    },
    {
      "matchUpdateTypes": ["patch", "minor"],
      "matchManagers": ["github-actions"],
      "groupName": "github-actions patch/minor"
    },
    {
      "matchUpdateTypes": ["patch", "minor"],
      "matchManagers": ["mise"],
      "groupName": "mise patch/minor"
    }
  ]
}
