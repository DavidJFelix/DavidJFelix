---
import {getCollection} from 'astro:content'
import {css} from 'styled-system/css'
import PostCard from '../../../components/PostCard.astro'
import BaseLayout from '../../../layouts/BaseLayout.astro'
import {collectTags, postsForTag} from '../../../lib/blog'

export async function getStaticPaths() {
  const posts = await getCollection('blog')

  return collectTags(posts).map((tag) => ({
    params: {tag},
    props: {tag, posts: postsForTag(posts, tag)},
  }))
}

const {tag, posts} = Astro.props
---

<BaseLayout title={`Posts tagged "${tag}"`} description={`Blog posts tagged with ${tag}`}>
  <div class={css({mb: '8'})}>
    <a
      href="/blog/tags"
      class={css({
        color: 'text.muted',
        textDecoration: 'none',
        fontSize: 'sm',
        _hover: {color: 'text'},
      })}
    >
      &larr; All tags
    </a>
  </div>

  <h1
    class={css({
      fontSize: '3xl',
      fontWeight: 'bold',
      mb: '8',
    })}
  >
    Posts tagged &ldquo;{tag}&rdquo;
  </h1>

  <div class={css({display: 'flex', flexDirection: 'column', gap: '6'})}>
    {posts.map((post) => <PostCard post={post} currentTag={tag} />)}
  </div>
</BaseLayout>
