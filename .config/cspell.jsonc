{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "en",
  "dictionaries": [
    "typescript",
    "node",
    "npm",
    "html",
    "css",
    "bash",
    "software-terms",
    "dns",
    "ics",
    "people-names",
    "pierre",
  ],
  // Topic dictionaries: system vocabularies and names shared by more than one
  // file. Entries and the reasons for them live in the .txt files themselves.
  "dictionaryDefinitions": [
    {"name": "dns", "path": "dictionaries/dns.txt", "description": "DNS response codes"},
    {
      "name": "ics",
      "path": "dictionaries/ics.txt",
      "description": "iCalendar (RFC 5545) property names",
    },
    {
      "name": "people-names",
      "path": "dictionaries/people-names.txt",
      "description": "People named in docs and code",
    },
    {
      "name": "pierre",
      "path": "dictionaries/pierre.txt",
      "description": "Pierre ecosystem vocabulary (diffs viewer port provenance)",
    },
  ],
  // Spellings this repo rejects outright; cspell reports the replacement. The
  // entry has to spell the word it bans, so exempt this file's own mention:
  // cSpell:ignore falsy
  "flagWords": ["falsy->falsey"],
  "ignorePaths": [
    "node_modules",
    "dist",
    "dist-flue",
    ".flue-vite",
    ".flue-vite.wrangler.jsonc",
    "build",
    ".git",
    "pnpm-lock.yaml",
    "*.lock",
    "*.min.js",
    "*.min.css",
    "styled-system",
    "routeTree.gen.ts",
    "*.gen.ts",
    ".astro",
    ".svelte-kit",
    ".nuxt",
    ".output",
    ".vinxi",
    ".tanstack",
    ".wrangler",
    ".vercel",
    ".alchemy",
    "coverage",
    "playwright-report",
    "test-results",
  ],
  "ignoreRegExpList": [
    // Bluesky DID identifiers (did:plc:...) -- prefix-anchored so the pattern
    // can never swallow prose.
    "did:plc:[a-z0-9]+",
    // Inline SVG data URIs.
    "data:image/svg\\+xml[^\"]+",
  ],
  // Only globally recognizable words belong here -- see
  // docs/contributing/spelling.md for the full decision ladder.
  "words": [
    // Real words and dev jargon the bundled dictionaries lack.
    "achievability",
    "actioned",
    "artmaking",
    "assed", // as in half-assed (blog voice)
    "backlinks",
    "browsable",
    "burndown",
    "codegen",
    "codemod",
    "commenters",
    "cookieless",
    "cooldown",
    "crawlable",
    "cutover",
    "deprioritized",
    "doomer",
    "effectful",
    "falsey", // the repo's preferred spelling; the conventional variant is in flagWords
    "footguns",
    "frontmatter",
    "gatekept",
    "geolocates", // the dictionaries lack this verb entirely
    "greppable",
    "hackathon",
    "headshot",
    "idempotently",
    "inlines",
    "lerp",
    "lintable",
    "lockfiles",
    "longhands",
    "misallocated",
    "orchestrable",
    "papercut",
    "papercuts",
    "pointable",
    "prerendered",
    "prerendering",
    "prerenders",
    "pushback",
    "relitigate",
    "repoints",
    "reprioritize",
    "reprioritized",
    "rescoped",
    "respawned",
    "rollouts",
    "stepback",
    "stepbacks",
    "subrequest",
    "subsetting",
    "templatize",
    "templatized",
    "templatizing",
    "timebox",
    "unawaited",
    "uncloneable",
    "unconfigured",
    "underbuilding",
    "uninlined",
    "unparseable",
    "unportable",
    "unprovisioned",
    "unreachability",
    "unrequested",
    "unreviewable",
    "upserts",
    "virtuals",
    "worktree",
    // Domain terms: AT Protocol, PostHog event vocabulary, standards.
    "atproto",
    "autocapture",
    "bsky",
    "fqns", // fully qualified names -- how alchemy keys resource state
    "pageleave",
    "pkce",
    "rkey",
    "wcag",
    "webidl",
    "webmentions",
    "xrpc", // the AT Protocol's HTTP API path prefix
    // Companies, products, tools, and fonts.
    "angelhack",
    "anthropics", // the GitHub org behind the claude-code action
    "artipacked", // a zizmor audit rule name
    "atumsoft",
    "clippy",
    "consolas",
    "dall", // DALL-E
    "devbox",
    "earendil", // the @earendil-works npm scope (pi coding agent)
    "exercism",
    "forgejo",
    "forza", // Italian ('force'/'go') -- forzamonica.com; cspell bundles no Italian dictionary
    "genai", // the @google/genai npm package (mise allow_builds, pnpm build allowlists)
    "getsentry",
    "ghalint",
    "gitea",
    "gofmt",
    "goimports",
    "golangci",
    "gopls",
    "goroot",
    "grotesk",
    "httpx",
    "hyperdrive",
    "instameals",
    "iotv",
    "iterm",
    "mattpocock", // renovate config preset handle
    "menlo",
    "miniflare",
    "msgpackr",
    "Neue", // Helvetica Neue, in font stacks
    "openclaw",
    "opencode",
    "openrouter",
    "oxfmtrc",
    "oxlint",
    "oxlintrc",
    "pandacss",
    "pepperonio",
    "pinact",
    "planetscale",
    "posthog",
    "proptest",
    "pulumi",
    "pyproject",
    "rspack",
    "schibsted",
    "shiki",
    "starlark",
    "strava",
    "supabase",
    "swarmfarm",
    "taskfile",
    "unconfig",
    "vinxi",
    "vndly",
    "workerd",
    "worktrunk",
    "xtask",
    "zizmor",
    "zstd",
    // This repo's own sites, handles, and blog coinages.
    "cringeposting",
    "davidfelix",
    "davidjfelix",
    "forzamonica",
    "monicandavid",
    "onvibes",
    "pkgdog",
    "ravrun",
    "shipposting",
    "startchi",
    "tokenmaxxing",
    "vibecoded",
    "yearroundrunning", // yearroundrunning.com, source of the reference marathon plan
    // Book and media titles.
    "cibola", // Cibola Burn, an Expanse novel on the reading list
    "stormlight", // the Stormlight Archive series on the reading list
  ],
}
