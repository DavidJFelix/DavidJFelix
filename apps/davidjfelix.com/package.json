{
  "name": "davidjfelix.com",
  "type": "module",
  "version": "0.0.1",
  "license": "(MIT OR Apache-2.0)",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check",
    "lint": "biome check . && oxlint",
    "lint:fix": "biome check --write . && oxlint --fix",
    "format": "oxfmt --check . && biome format . && prettier --check --no-error-on-unmatched-pattern \"**/*.md\" \"**/*.mdx\"",
    "format:fix": "oxfmt . && biome format --write . && prettier --write --no-error-on-unmatched-pattern \"**/*.md\" \"**/*.mdx\"",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.0.0",
    "@sentry/astro": "^10.60.0",
    "astro": "^7.0.0",
    "posthog-js": "^1.393.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@playwright/test": "1.61.1",
    "@sentry/cloudflare": "10.65.0",
    "@types/bun": "1.3.14",
    "@typescript/native-preview": "latest",
    "@vitest/coverage-v8": "4.1.10",
    "vitest": "4.1.10",
    "wrangler": "4.110.0"
  }
}
