---
import {css} from 'styled-system/css'

const trigger = css({
  display: 'flex',
  alignItems: 'center',
  gap: '2',
  color: 'zinc.400',
  bg: 'transparent',
  cursor: 'pointer',
  _hover: {color: 'zinc.100'},
})

const hint = css({
  borderWidth: '1px',
  borderStyle: 'solid',
  borderColor: 'zinc.700',
  borderRadius: 'sm',
  px: '1.5',
  fontSize: 'xs',
  color: 'zinc.500',
})

// Ctrl K vs ⌘K is picked by CSS from the data-platform attribute BaseLayout sets
// before first paint, so the right key shows immediately without a flash.
const onlyOtherPlatforms = css({'[data-platform=mac] &': {display: 'none'}})
const onlyMac = css({display: 'none', '[data-platform=mac] &': {display: 'inline'}})

const dialog = css({
  w: 'full',
  maxW: 'xl',
  mt: '15vh',
  mx: 'auto',
  bg: 'zinc.900',
  color: 'zinc.100',
  borderWidth: '1px',
  borderStyle: 'solid',
  borderColor: 'zinc.700',
  borderRadius: 'lg',
  p: '0',
  boxShadow: 'xl',
  _backdrop: {bg: 'black/60'},
})

const input = css({
  width: 'full',
  bg: 'zinc.950',
  color: 'zinc.100',
  borderWidth: '1px',
  borderStyle: 'solid',
  borderColor: 'zinc.700',
  borderRadius: 'md',
  px: '3',
  py: '2',
  _focus: {outline: 'none', borderColor: 'zinc.500'},
  _placeholder: {color: 'zinc.500'},
})

const status = css({color: 'zinc.400', px: '3', py: '4'})

// Results are built by the script below, so their styling lives here as
// descendant rules rather than per-node classes.
const results = css({
  listStyle: 'none',
  mt: '2',
  maxH: '60vh',
  overflowY: 'auto',
  '& a': {
    display: 'block',
    px: '3',
    py: '2',
    borderRadius: 'md',
    textDecoration: 'none',
    _hover: {bg: 'zinc.800'},
  },
  '& span': {display: 'block'},
  '& span:first-child': {color: 'zinc.100', fontWeight: 'semibold'},
  '& span:last-child': {color: 'zinc.400', fontSize: 'sm'},
  '& mark': {bg: 'transparent', color: 'blue.400', fontWeight: 'semibold'},
})
---

<button type="button" id="search-button" class={trigger}>Search
  <kbd class={hint}><span class={onlyOtherPlatforms}>Ctrl K</span><span class={onlyMac}>⌘K</span></kbd>
</button>

<dialog id="search-dialog" aria-label="Search posts" closedby="any" class={dialog}>
  <div class={css({p: '3'})}>
    <input
      type="search"
      id="search-input"
      aria-label="Search posts"
      placeholder="Search posts…"
      class={input}
    />
    <p id="search-status" class={status} hidden></p>
    <ul id="search-results" class={results}></ul>
  </div>
</dialog>

<script>
  interface PagefindFragment {
    url: string
    excerpt: string
    meta: {title?: string}
  }
  interface PagefindResult {
    data: () => Promise<PagefindFragment>
  }
  interface Pagefind {
    debouncedSearch: (query: string) => Promise<{results: PagefindResult[]} | null>
  }

  const RESULT_LIMIT = 8
  const INDEX_MISSING =
    'The search index is only generated by production builds — run a build to search locally.'

  const button = document.querySelector<HTMLButtonElement>('#search-button')
  const dialog = document.querySelector<HTMLDialogElement>('#search-dialog')
  const input = document.querySelector<HTMLInputElement>('#search-input')
  const results = document.querySelector<HTMLUListElement>('#search-results')
  const status = document.querySelector<HTMLParagraphElement>('#search-status')

  if (button && dialog && input && results && status) {
    // Pagefind's bundle is emitted only by `astro build`, so it never exists
    // under `astro dev`; load it on first use and cache the result (null if it
    // is missing, which is the dev case).
    let pagefind: Promise<Pagefind | null> | undefined
    const loadPagefind = () => {
      if (!pagefind) {
        const url = '/pagefind/pagefind.js'
        pagefind = import(/* @vite-ignore */ url).then(
          (module: Pagefind) => module,
          () => null,
        )
      }
      return pagefind
    }

    // Bumped per query and on close so superseded async results are dropped.
    let token = 0

    const reset = () => {
      results.replaceChildren()
      status.hidden = true
    }

    const showStatus = (message: string) => {
      results.replaceChildren()
      status.textContent = message
      status.hidden = false
    }

    const showResults = (fragments: PagefindFragment[]) => {
      status.hidden = true
      results.replaceChildren(
        ...fragments.map(({url, excerpt, meta}) => {
          const title = document.createElement('span')
          title.textContent = meta.title ?? url
          const snippet = document.createElement('span')
          snippet.innerHTML = excerpt // pagefind builds excerpts from this site's own content
          const link = document.createElement('a')
          link.href = url
          link.append(title, snippet)
          const item = document.createElement('li')
          item.append(link)
          return item
        }),
      )
    }

    const search = async (value: string) => {
      const mine = ++token
      if (!value) {
        reset()
        return
      }
      const api = await loadPagefind()
      if (!api) {
        showStatus(INDEX_MISSING)
        return
      }
      const found = await api.debouncedSearch(value)
      if (!found || mine !== token) return
      const fragments = await Promise.all(
        found.results.slice(0, RESULT_LIMIT).map((result) => result.data()),
      )
      if (mine !== token) return
      if (fragments.length === 0) {
        showStatus(`No results for “${value}”`)
      } else {
        showResults(fragments)
      }
    }

    button.addEventListener('click', () => dialog.showModal())
    input.addEventListener('input', () => void search(input.value))
    dialog.addEventListener('close', () => {
      token++
      input.value = ''
      reset()
    })
    window.addEventListener('keydown', (event) => {
      if (event.key === 'k' && (event.metaKey || event.ctrlKey)) {
        event.preventDefault()
        if (dialog.open) {
          dialog.close()
        } else {
          dialog.showModal()
        }
      }
    })
  }
</script>
