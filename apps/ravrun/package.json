{
  "name": "ravrun",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "dev": "vite --port=3001",
    "build": "vite build",
    "serve": "vite preview",
    "start": "vite",
    "lint": "biome check . && oxlint",
    "lint:fix": "biome check --write .",
    "format": "biome format . && prettier --check --no-error-on-unmatched-pattern \"**/*.md\" \"**/*.mdx\"",
    "format:fix": "biome format --write . && prettier --write --no-error-on-unmatched-pattern \"**/*.md\" \"**/*.mdx\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "spell": "cspell --config ../../.config/cspell.json \"**\""
  },
  "devDependencies": {
    "@cspell/dict-typescript": "3.2.3",
    "@tanstack/router-plugin": "1.168.14",
    "@types/node": "25.9.1",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "latest",
    "@vitejs/plugin-react": "6.0.2",
    "cspell": "10.0.1",
    "jsdom": "29.1.1",
    "vite": "8.0.16",
    "vitest": "4.1.8",
    "wrangler": "4.98.0"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.170.8",
    "@tanstack/router-devtools": "^1.167.0",
    "date-fns": "^4.3.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "engines": {
    "node": ">=24"
  }
}
