---
import {Image} from 'astro:assets'
import {getCollection} from 'astro:content'
import {css} from 'styled-system/css'
import headshot from '../assets/headshot.png'
import PostCard from '../components/PostCard.astro'
import BaseLayout from '../layouts/BaseLayout.astro'
import {sortPostsByDateDesc} from '../lib/blog'
import {person, webSite} from '../lib/structured-data'

const recentPosts = sortPostsByDateDesc(await getCollection('blog')).slice(0, 3)
---

<BaseLayout
  title="David J Felix"
  description="Personal blog of David J Felix"
  jsonLd={[webSite(Astro.site), person(Astro.site)]}
>
  <div class={css({display: 'flex', flexDirection: 'column', gap: '12'})}>
    <section
      class={css({
        display: 'flex',
        flexDirection: {base: 'column', md: 'row'},
        alignItems: 'center',
        gap: '8',
      })}
    >
      <Image
        src={headshot}
        alt="David J Felix"
        class={css({
          w: '40',
          h: '40',
          borderRadius: 'full',
          borderWidth: '4px',
          borderStyle: 'solid',
          borderColor: 'border',
        })}
      />
      <div>
        <h1 class={css({fontSize: '4xl', fontWeight: 'bold', mb: '2'})}>David J Felix</h1>
        <p class={css({color: 'text.muted', fontSize: 'lg'})}>It's all downhill from here</p>
      </div>
    </section>

    <section>
      <div
        class={css({
          display: 'flex',
          alignItems: 'baseline',
          justifyContent: 'space-between',
          mb: '6',
        })}
      >
        <h2 class={css({fontSize: '2xl', fontWeight: 'bold'})}>Recent posts</h2>
        <a
          href="/blog"
          class={css({
            color: 'accent.text',
            textDecoration: 'none',
            fontSize: 'sm',
            _hover: {textDecoration: 'underline'},
          })}
        >
          All posts &rarr;
        </a>
      </div>

      <div class={css({display: 'flex', flexDirection: 'column', gap: '6'})}>
        {recentPosts.map((post) => <PostCard post={post} headingLevel="h3" showTags={false} />)}
      </div>
    </section>
  </div>
</BaseLayout>
