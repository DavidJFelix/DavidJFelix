---
import '../index.css'
import '@fontsource-variable/schibsted-grotesk'
import '@fontsource-variable/inter'
import '@fontsource-variable/jetbrains-mono'
import {css} from 'styled-system/css'
import Analytics from '../components/Analytics.astro'
import Search from '../components/Search.astro'
import ThemeToggle from '../components/ThemeToggle.astro'
import {publicationUri} from '../lib/standard-site'

interface Props {
  title: string
  description?: string
  ogType?: 'website' | 'article'
  ogImage?: string
}

const {
  title,
  description = 'Personal blog of David J Felix',
  ogType = 'website',
  ogImage = '/og/default.png',
} = Astro.props

// Pages build with the default directory format, so published URLs end with a
// trailing slash; normalize the canonical to match what the sitemap emits.
const pathname = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`
const canonicalUrl = Astro.site ? new URL(pathname, Astro.site) : undefined
const ogImageUrl = Astro.site ? new URL(ogImage, Astro.site) : undefined

// Only ship analytics on builds that carry the key (production deploy). The
// component guards on the key at runtime too; gating the render here keeps it
// out of local/CI/preview output entirely.
const posthogEnabled = Boolean(import.meta.env.PUBLIC_POSTHOG_KEY)

const navLink = css({
  color: 'text.muted',
  textDecoration: 'none',
  _hover: {color: 'text'},
})
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {/* Resolve the color theme before first paint so there is no flash: an
        explicit choice in localStorage wins, otherwise follow the system. */}
    <script is:inline>
      const storedTheme = localStorage.getItem('theme')
      document.documentElement.dataset.theme =
        storedTheme === 'light' || storedTheme === 'dark'
          ? storedTheme
          : matchMedia('(prefers-color-scheme: dark)').matches
            ? 'dark'
            : 'light'
    </script>
    {/* Tag the platform before first paint so the search hotkey hint renders as
        ⌘K (Mac) or Ctrl K immediately, instead of flashing after hydration. */}
    <script is:inline>
      if (/Mac|iPhone|iPad/.test(navigator.platform)) {
        document.documentElement.dataset.platform = 'mac'
      }
    </script>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | djf.io</title>
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="djf.io" />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    {ogImageUrl && <meta property="og:image:width" content="1200" />}
    {ogImageUrl && <meta property="og:image:height" content="630" />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@davidjfelix" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
    <link
      rel="alternate"
      type="application/rss+xml"
      title="David J. Felix's Blog"
      href="/rss.xml"
    />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="site.standard.publication" href={publicationUri()} />
    {posthogEnabled && <Analytics />}
    <slot name="head" />
  </head>
  <body
    class={css({
      fontFamily: 'body',
      bg: 'bg.canvas',
      color: 'text',
      minH: '100vh',
      lineHeight: '1.6',
    })}
  >
    <header
      class={css({
        borderBottom: '1px solid',
        borderBottomColor: 'border.subtle',
        py: '4',
      })}
    >
      <nav
        class={css({
          maxW: '3xl',
          mx: 'auto',
          px: '4',
          display: 'flex',
          justifyContent: 'space-between',
          alignItems: 'center',
        })}
      >
        <a
          href="/"
          class={css({
            fontSize: 'xl',
            fontWeight: 'bold',
            color: 'text',
            textDecoration: 'none',
            _hover: {color: 'accent.text'},
          })}
        >
          djf.io
        </a>
        <div class={css({display: 'flex', alignItems: 'center', gap: '6'})}>
          <Search />
          <a href="/blog" class={navLink}>Blog</a>
          <a href="/about" class={navLink}>About</a>
          <a href="https://github.com/davidjfelix" class={navLink}>GitHub</a>
          <a href="https://twitter.com/davidjfelix" class={navLink}>Twitter</a>
          <ThemeToggle />
        </div>
      </nav>
    </header>

    <main
      class={css({
        maxW: '3xl',
        mx: 'auto',
        px: '4',
        py: '8',
      })}
    >
      <slot />
    </main>

    <footer
      class={css({
        borderTop: '1px solid',
        borderTopColor: 'border.subtle',
        py: '6',
        mt: '12',
      })}
    >
      <div
        class={css({
          maxW: '3xl',
          mx: 'auto',
          px: '4',
          textAlign: 'center',
          color: 'text.muted',
          fontSize: 'sm',
        })}
      >
        &copy; {new Date().getFullYear()} David J Felix. All rights reserved.
      </div>
    </footer>
  </body>
</html>
