{
  "name": "@davidjfelix/djf.io",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "prepare": "panda codegen",
    "dev": "astro dev",
    "start": "astro dev",
    "build": "panda codegen && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "biome check . && oxlint",
    "lint:fix": "biome check --write .",
    "format": "biome format --write . && prettier --write .",
    "spell": "cspell --config ../../.config/cspell.json \"**\"",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/mdx": "^4.0.0",
    "@astrojs/react": "^4.4.2",
    "@astrojs/rss": "^4.0.15",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "astro": "^5.18.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.0",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@cspell/dict-typescript": "^3.2.0",
    "@pandacss/dev": "1.7.2",
    "@playwright/test": "^1.50.0",
    "cspell": "^9.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=24"
  }
}
