{
  "name": "@davidjfelix/pkg.dog",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev --port 3004",
    "prepare": "panda codegen && nuxt prepare",
    "build": "panda codegen && nuxt build",
    "preview": "nuxt preview",
    "deploy": "pnpm run build && wrangler deploy",
    "lint": "biome check . && oxlint",
    "lint:fix": "biome check --write . && oxlint --fix",
    "format": "oxfmt --check . && prettier --check --no-error-on-unmatched-pattern \"**/*.md\" \"**/*.mdx\"",
    "format:fix": "oxfmt . && prettier --write --no-error-on-unmatched-pattern \"**/*.md\" \"**/*.mdx\"",
    "typecheck": "nuxt typecheck",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@ark-ui/vue": "^5.37.2",
    "@sentry/browser": "^10.60.0",
    "nuxt": "^4.4.8",
    "posthog-js": "^1.393.0",
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@pandacss/dev": "1.11.4",
    "@playwright/test": "1.61.1",
    "@vitest/coverage-v8": "4.1.10",
    "typescript": "6.0.3",
    "vitest": "4.1.10",
    "vue-tsc": "3.3.7",
    "wrangler": "4.107.1"
  }
}
