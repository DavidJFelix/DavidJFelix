{
  "name": "@davidjfelix/djf.io",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "prepare": "panda codegen",
    "dev": "astro dev",
    "start": "astro dev",
    "build": "panda codegen && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "biome check . && oxlint",
    "lint:fix": "biome check --write .",
    "format": "biome format --write . && prettier --write .",
    "spell": "cspell --config ../../.config/cspell.json \"**\"",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/react": "^5.0.4",
    "@astrojs/rss": "^4.0.18",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.3.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sharp": "^0.34.5",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@cspell/dict-typescript": "^3.2.3",
    "@pandacss/dev": "1.11.1",
    "@playwright/test": "^1.60.0",
    "cspell": "^9.4.0",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=24"
  }
}
