---
const title = 'David J. Felix'
const description = 'Personal site of David J. Felix.'
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <style>
      :root {
        color-scheme: dark;
        --bg: #09090b;
        --fg: #e4e4e7;
        --muted: #a1a1aa;
        --accent: #f4f4f5;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        background: var(--bg);
        color: var(--fg);
        font-family: ui-sans-serif, system-ui, -apple-system, sans-serif;
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 2rem;
      }
      main {
        max-width: 36rem;
        text-align: left;
      }
      h1 {
        font-size: clamp(2.5rem, 6vw, 4rem);
        font-weight: 700;
        letter-spacing: -0.03em;
        margin: 0 0 1rem;
        color: var(--accent);
      }
      p {
        font-size: 1.125rem;
        line-height: 1.6;
        color: var(--muted);
        margin: 0 0 1.5rem;
      }
      ul {
        list-style: none;
        padding: 0;
        margin: 2rem 0 0;
        display: flex;
        flex-wrap: wrap;
        gap: 1rem 1.5rem;
      }
      a {
        color: var(--fg);
        text-decoration: none;
        border-bottom: 1px solid var(--muted);
        padding-bottom: 1px;
        transition: border-color 120ms ease;
      }
      a:hover { border-color: var(--accent); }
    </style>
  </head>
  <body>
    <main>
      <h1>David J. Felix</h1>
      <p>Software engineer. This is my corner of the web.</p>
      <ul>
        <li><a href="https://djf.io">blog</a></li>
        <li><a href="https://github.com/davidjfelix">github</a></li>
      </ul>
    </main>
  </body>
</html>
