{
  "name": "@davidjfelix/djf.io",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "prepare": "panda codegen",
    "dev": "astro dev",
    "start": "astro dev",
    "build": "panda codegen && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check",
    "lint": "biome check . && oxlint",
    "lint:fix": "biome check --write .",
    "format": "biome format . && prettier --check --no-error-on-unmatched-pattern \"**/*.md\" \"**/*.mdx\"",
    "format:fix": "biome format --write . && prettier --write --no-error-on-unmatched-pattern \"**/*.md\" \"**/*.mdx\"",
    "spell": "cspell --config ../../.config/cspell.json \"**\"",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/mdx": "^6.0.0",
    "@astrojs/react": "^5.0.5",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource/inter": "^5.2.8",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "latest",
    "astro": "^6.4.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "satori": "^0.26.0",
    "sharp": "^0.35.0"
  },
  "devDependencies": {
    "@cspell/dict-typescript": "3.2.3",
    "@pandacss/dev": "1.11.3",
    "@playwright/test": "1.60.0",
    "cspell": "10.0.1",
    "pagefind": "1.5.2",
    "vitest": "4.1.8",
    "wrangler": "4.100.0"
  },
  "engines": {
    "node": ">=24"
  }
}
