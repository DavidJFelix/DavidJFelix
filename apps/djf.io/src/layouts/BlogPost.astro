---
import {Image} from 'astro:assets'
import type {CollectionEntry} from 'astro:content'
import {css} from 'styled-system/css'
import {prose} from 'styled-system/recipes'
import {formatBlogDate} from '../lib/blog'
import {documentUri} from '../lib/standard-site-resolve'
import {breadcrumbs} from '../lib/structured-data'
import BaseLayout from './BaseLayout.astro'

interface Props {
  post: CollectionEntry<'blog'>
  // Chronological neighbors, for the reader and for crawlable internal links.
  prev?: CollectionEntry<'blog'>
  next?: CollectionEntry<'blog'>
}

const {post, prev, next} = Astro.props
const {title, description, date, author, tags, readingTime, hero} = post.data

const formattedDate = formatBlogDate(date)

// Resolved from the live PDS only when the deploy opts in (STANDARD_SITE_RESOLVE);
// null otherwise, so the link is omitted in offline/local/CI builds.
const standardDocumentUri = await documentUri(post.id)

const ogImage = `/og/blog/${post.id}.png`
const postUrl = Astro.site ? new URL(`/blog/${post.id}/`, Astro.site) : undefined
const blogPosting = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: date.toISOString(),
  author: {'@type': 'Person', name: author ?? 'David J Felix'},
  url: postUrl,
  mainEntityOfPage: postUrl && {'@type': 'WebPage', '@id': postUrl},
  image: Astro.site ? new URL(ogImage, Astro.site) : undefined,
  keywords: tags?.join(', '),
}
const jsonLd = [
  blogPosting,
  breadcrumbs(Astro.site, [
    {name: 'Home', path: '/'},
    {name: 'Blog', path: '/blog/'},
    {name: title, path: `/blog/${post.id}/`},
  ]),
]

const neighborLink = css({
  color: 'accent.text',
  textDecoration: 'none',
  _hover: {textDecoration: 'underline'},
})
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  ogImage={ogImage}
  ogImageAlt={`Title card for ${title} on djf.io`}
  article={{publishedTime: date.toISOString(), author: author ?? 'David J Felix', tags}}
  jsonLd={jsonLd}
  standardDocumentUri={standardDocumentUri}
>
  <article data-pagefind-body>
    <header
      class={css({
        mb: '8',
        display: 'flex',
        flexDirection: {base: 'column-reverse', md: 'row'},
        alignItems: {base: 'flex-start', md: 'center'},
        justifyContent: 'space-between',
        gap: '6',
      })}
    >
      <div>
        <h1
          class={css({
            fontSize: '4xl',
            fontWeight: 'bold',
            mb: '4',
            lineHeight: '1.2',
          })}
        >
          {title}
        </h1>

        <div
          class={css({
            display: 'flex',
            flexWrap: 'wrap',
            gap: '4',
            color: 'text.muted',
            fontSize: 'sm',
            mb: '4',
          })}
        >
          <span>{formattedDate}</span>
          {author && <span>by {author}</span>}
          {readingTime && <span>{readingTime} read</span>}
        </div>

        {
          tags && tags.length > 0 && (
            <div class={css({display: 'flex', flexWrap: 'wrap', gap: '2'})}>
              {tags.map((tag: string) => (
                <a
                  href={`/blog/tags/${tag}`}
                  class={css({
                    bg: 'bg.element',
                    color: 'text.muted',
                    px: '2',
                    py: '1',
                    borderRadius: 'md',
                    fontSize: 'xs',
                    textDecoration: 'none',
                    _hover: {bg: 'bg.elementHover', color: 'text'},
                  })}
                >
                  {tag}
                </a>
              ))}
            </div>
          )
        }
      </div>

      {
        hero?.image && (
          <Image
            src={hero.image.file}
            alt={hero.image.alt}
            width={160}
            height={160}
            densities={[1, 2]}
            loading="eager"
            fetchpriority="high"
            class={css({
              flexShrink: 0,
              borderRadius: 'lg',
            })}
          />
        )
      }
    </header>

    <div class={prose()}>
      <slot />
    </div>
  </article>

  {/* Outside the article so pagefind does not index neighbor titles into
      this page's search entry. */}
  {
    (prev || next) && (
      <nav
        aria-label="More posts"
        class={css({
          display: 'flex',
          justifyContent: 'space-between',
          gap: '4',
          mt: '12',
          pt: '6',
          borderTop: '1px solid',
          borderTopColor: 'border.subtle',
          fontSize: 'sm',
        })}
      >
        <div>
          {prev && (
            <a href={`/blog/${prev.id}`} class={neighborLink}>
              &larr; {prev.data.title}
            </a>
          )}
        </div>
        <div class={css({textAlign: 'right'})}>
          {next && (
            <a href={`/blog/${next.id}`} class={neighborLink}>
              {next.data.title} &rarr;
            </a>
          )}
        </div>
      </nav>
    )
  }
</BaseLayout>
