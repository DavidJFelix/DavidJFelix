{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices"],
  "timezone": "UTC",
  "schedule": ["before 5am on monday"],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 5am on monday"]
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  },
  "github-actions": {
    "description": "Workflows live in .depot/workflows/ (Depot CI), which the manager's default patterns do not cover; the action.yaml pattern re-adds composite-action coverage in case patterns replace rather than extend the defaults.",
    "managerFilePatterns": ["/^\\.depot/workflows/[^/]+\\.ya?ml$/", "/(^|/)action\\.ya?ml$/"]
  },
  "packageRules": [
    {
      "matchUpdateTypes": ["patch", "minor"],
      "matchManagers": ["npm"],
      "groupName": "npm patch/minor"
    },
    {
      "matchUpdateTypes": ["patch", "minor"],
      "matchManagers": ["cargo"],
      "groupName": "cargo patch/minor"
    },
    {
      "matchUpdateTypes": ["patch", "minor"],
      "matchManagers": ["github-actions"],
      "groupName": "github-actions patch/minor"
    },
    {
      "matchUpdateTypes": ["patch", "minor"],
      "matchManagers": ["mise"],
      "groupName": "mise patch/minor"
    }
  ]
}
