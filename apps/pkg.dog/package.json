{
  "name": "@davidjfelix/pkg.dog",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev --port 3004",
    "prepare": "panda codegen && nuxt prepare",
    "build": "panda codegen && nuxt build",
    "preview": "nuxt preview",
    "deploy": "pnpm run build && wrangler deploy",
    "lint": "biome check . && oxlint",
    "lint:fix": "biome check --write .",
    "format": "biome format . && prettier --check --no-error-on-unmatched-pattern \"**/*.md\" \"**/*.mdx\"",
    "format:fix": "biome format --write . && prettier --write --no-error-on-unmatched-pattern \"**/*.md\" \"**/*.mdx\"",
    "typecheck": "nuxt typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@ark-ui/vue": "^5.37.2",
    "nuxt": "^4.4.8",
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@pandacss/dev": "1.11.3",
    "@playwright/test": "1.61.0",
    "typescript": "6.0.3",
    "vitest": "4.1.9",
    "vue-tsc": "3.3.5",
    "wrangler": "4.103.0"
  }
}
