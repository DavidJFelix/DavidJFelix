{
  "name": "@davidjfelix/onvibes.org",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "panda codegen",
    "dev": "astro dev",
    "dev:worker": "flue dev --target cloudflare",
    "build": "pnpm run build:astro && pnpm run build:worker",
    "build:astro": "panda codegen && astro build",
    "build:worker": "flue build --target cloudflare && bun bin/patch-flue-wrangler.ts",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check",
    "lint": "biome check . && oxlint",
    "lint:fix": "biome check --write .",
    "format": "biome format . && prettier --check --no-error-on-unmatched-pattern \"**/*.md\" \"**/*.mdx\"",
    "format:fix": "biome format --write . && prettier --write --no-error-on-unmatched-pattern \"**/*.md\" \"**/*.mdx\"",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.1",
    "@earendil-works/pi-ai": "0.80.3",
    "@flue/react": "1.0.0-beta.8",
    "@flue/runtime": "1.0.0-beta.8",
    "@flue/sdk": "1.0.0-beta.8",
    "@sentry/astro": "^10.63.0",
    "agents": "^0.17.3",
    "astro": "^7.0.6",
    "hono": "4.12.27",
    "posthog-js": "^1.396.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/react": "^6.0.1",
    "@flue/cli": "1.0.0-beta.8",
    "@pandacss/dev": "1.11.4",
    "@playwright/test": "1.61.1",
    "@sentry/cloudflare": "10.63.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "4.1.9",
    "vitest": "4.1.9",
    "wrangler": "4.107.0"
  }
}
