{
  "root": false,
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "extends": ["../../biome.jsonc"],
  "files": {
    "includes": ["**", "!src/routeTree.gen.ts"]
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "linter": {
    "rules": {
      "style": {
        "useFragmentSyntax": "error"
      },
      "correctness": {
        "useHookAtTopLevel": "error"
      }
    }
  }
}
