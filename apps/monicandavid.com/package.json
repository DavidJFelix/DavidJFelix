{
  "name": "@davidjfelix/monicandavid.com",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3003",
    "prepare": "svelte-kit sync && panda codegen",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "pnpm run build && wrangler deploy",
    "lint": "biome check . && oxlint",
    "lint:fix": "biome check --write .",
    "format": "biome format . && prettier --check --no-error-on-unmatched-pattern \"**/*.md\" \"**/*.mdx\"",
    "format:fix": "biome format --write . && prettier --write --no-error-on-unmatched-pattern \"**/*.md\" \"**/*.mdx\"",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@ark-ui/svelte": "^5.22.1",
    "@sentry/browser": "^10.63.0",
    "posthog-js": "^1.396.6"
  },
  "devDependencies": {
    "@pandacss/dev": "1.11.4",
    "@playwright/test": "1.61.1",
    "@sveltejs/adapter-cloudflare": "7.2.9",
    "@sveltejs/kit": "2.69.1",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@types/node": "25.9.4",
    "@vitest/coverage-v8": "4.1.9",
    "svelte": "5.56.4",
    "svelte-check": "4.7.1",
    "typescript": "6.0.3",
    "vite": "8.1.3",
    "vitest": "4.1.9",
    "wrangler": "4.107.0"
  }
}
