{
  "root": false,
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
  "extends": ["../../biome.jsonc"],
  "files": {
    "includes": [
      "**",
      "!src/routeTree.gen.ts",
      "!styled-system",
      "!.wrangler",
      "!dist",
      "!node_modules"
    ]
