{
  "name": "calendar-visualizer",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "prepare": "panda codegen",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check",
    "lint": "biome check . && oxlint",
    "lint:fix": "biome check --write .",
    "format": "biome format . && prettier --check --no-error-on-unmatched-pattern \"**/*.md\" \"**/*.mdx\"",
    "format:fix": "biome format --write . && prettier --write --no-error-on-unmatched-pattern \"**/*.md\" \"**/*.mdx\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "spell": "cspell --config ../../.config/cspell.json \"**\""
  },
  "dependencies": {
    "@astrojs/react": "^5.0.5",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.3.7",
    "date-fns": "^4.3.0",
    "date-holidays": "^3.30.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@cspell/dict-typescript": "3.2.3",
    "@pandacss/dev": "1.11.2",
    "cspell": "10.0.1",
    "vitest": "4.1.8",
    "wrangler": "4.98.0"
  }
}
