    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "latest",
    "@vitejs/plugin-react": "^6.0.1",
    "cspell": "^10.0.0",
    "vite": "^8.0.14"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.170.10",
    "@tanstack/router-devtools": "^1.167.0",
    "date-fns": "^4.4.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "engines": {
    "node": ">=24"
  }
