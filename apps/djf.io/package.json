{
  "name": "@davidjfelix/djf.io",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "prepare": "panda codegen",
    "dev": "astro dev",
    "start": "astro dev",
    "build": "panda codegen && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check",
    "lint": "biome check . && oxlint",
    "lint:fix": "biome check --write .",
    "format": "biome format . && prettier --check --no-error-on-unmatched-pattern \"**/*.md\" \"**/*.mdx\"",
    "format:fix": "biome format --write . && prettier --write --no-error-on-unmatched-pattern \"**/*.md\" \"**/*.mdx\"",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:unit": "vitest run --coverage",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^13.7.0",
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/schibsted-grotesk": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@radix-ui/colors": "^3.0.0",
    "@sentry/astro": "^10.62.0",
    "@types/react": "^19.2.17",
    "@typescript/native-preview": "latest",
    "astro": "^6.4.6",
    "posthog-js": "^1.395.0",
    "satori": "^0.26.0",
    "sharp": "^0.35.1"
  },
  "devDependencies": {
    "@atproto/api": "0.20.22",
    "@pandacss/dev": "1.11.4",
    "@playwright/test": "1.61.1",
    "@sentry/cloudflare": "^10.62.0",
    "@vitest/coverage-v8": "4.1.9",
    "gray-matter": "4.0.3",
    "pagefind": "1.5.2",
    "vitest": "4.1.9",
    "wrangler": "4.105.0"
  },
  "engines": {
    "node": ">=24"
  }
}
