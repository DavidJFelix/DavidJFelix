---
import '../index.css'
import '@fontsource-variable/schibsted-grotesk'
import '@fontsource-variable/inter'
import '@fontsource-variable/jetbrains-mono'
import {css} from 'styled-system/css'
import Search from '../components/Search'
import {publicationUri} from '../lib/standard-site'

interface Props {
  title: string
  description?: string
  ogType?: 'website' | 'article'
  ogImage?: string
}

const {
  title,
  description = 'Personal blog of David J Felix',
  ogType = 'website',
  ogImage = '/og/default.png',
} = Astro.props

// Pages build with the default directory format, so published URLs end with a
// trailing slash; normalize the canonical to match what the sitemap emits.
const pathname = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`
const canonicalUrl = Astro.site ? new URL(pathname, Astro.site) : undefined
const ogImageUrl = Astro.site ? new URL(ogImage, Astro.site) : undefined
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | djf.io</title>
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="djf.io" />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    {ogImageUrl && <meta property="og:image:width" content="1200" />}
    {ogImageUrl && <meta property="og:image:height" content="630" />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@davidjfelix" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
    <link
      rel="alternate"
      type="application/rss+xml"
      title="David J. Felix's Blog"
      href="/rss.xml"
    />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="site.standard.publication" href={publicationUri()} />
    <slot name="head" />
  </head>
  <body
    class={css({
      fontFamily: 'body',
      bg: 'zinc.950',
      color: 'zinc.100',
      minH: '100vh',
      lineHeight: '1.6',
    })}
  >
    <header
      class={css({
        borderBottom: '1px solid',
        borderBottomColor: 'zinc.800',
        py: '4',
      })}
    >
      <nav
        class={css({
          maxW: '4xl',
          mx: 'auto',
          px: '4',
          display: 'flex',
          justifyContent: 'space-between',
          alignItems: 'center',
        })}
      >
        <a
          href="/"
          class={css({
            fontSize: 'xl',
            fontWeight: 'bold',
            color: 'zinc.100',
            textDecoration: 'none',
            _hover: {color: 'zinc.300'},
          })}
        >
          djf.io
        </a>
        <div class={css({display: 'flex', alignItems: 'center', gap: '6'})}>
          <Search client:load />
          <a
            href="/blog"
            class={css({
              color: 'zinc.400',
              textDecoration: 'none',
              _hover: {color: 'zinc.100'},
            })}
          >
            Blog
          </a>
          <a
            href="https://github.com/davidjfelix"
            class={css({
              color: 'zinc.400',
              textDecoration: 'none',
              _hover: {color: 'zinc.100'},
            })}
          >
            GitHub
          </a>
          <a
            href="https://twitter.com/davidjfelix"
            class={css({
              color: 'zinc.400',
              textDecoration: 'none',
              _hover: {color: 'zinc.100'},
            })}
          >
            Twitter
          </a>
        </div>
      </nav>
    </header>

    <main
      class={css({
        maxW: '4xl',
        mx: 'auto',
        px: '4',
        py: '8',
      })}
    >
      <slot />
    </main>

    <footer
      class={css({
        borderTop: '1px solid',
        borderTopColor: 'zinc.800',
        py: '6',
        mt: '12',
      })}
    >
      <div
        class={css({
          maxW: '4xl',
          mx: 'auto',
          px: '4',
          textAlign: 'center',
          color: 'zinc.400',
          fontSize: 'sm',
        })}
      >
        &copy; {new Date().getFullYear()} David J Felix. All rights reserved.
      </div>
    </footer>
  </body>
</html>
